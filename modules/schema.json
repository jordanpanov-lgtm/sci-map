{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jordanpanov-lgtm.github.io/sci-map/modules/schema.json",
  "title": "Sci-Map Folio",
  "description": "Machine-checkable contract for a single folio file. The human companion is FIELD_GUIDE.md; where the two disagree, this schema is what CI enforces. Referential rules that JSON Schema cannot express (link resolution, xlink resolution across folios, _index sync, timeline refs) are enforced by validate.js.",
  "type": "object",
  "required": ["id", "title", "subtitle", "period", "domain", "mapCenter", "mapZoom", "methodology", "categories", "timeline"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "integer", "minimum": 1 },
    "period": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "integer" },
        "end": { "type": "integer" }
      }
    },
    "domain": {
      "type": "string",
      "enum": [
        "formal-computing", "physical-sciences", "earth-space", "life-sciences",
        "human-biology", "psychology", "language", "society", "civics", "philosophy"
      ]
    },
    "mapCenter": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    },
    "mapZoom": { "type": "number" },
    "methodology": { "type": "string", "minLength": 1 },
    "categories": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/category" }
    },
    "timeline": {
      "type": "array",
      "items": { "$ref": "#/$defs/lane" }
    }
  },
  "$defs": {
    "category": {
      "type": "object",
      "required": ["id", "label", "entries"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["theory", "study", "effect", "concept", "method", "figure", "debate", "application"]
        },
        "label": { "type": "string" },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/entry" }
        }
      }
    },
    "entry": {
      "type": "object",
      "required": ["id", "group", "label", "date", "loc", "coords", "links", "hint", "tag", "note"],
      "not": {
        "anyOf": [
          { "required": ["fig"] },
          { "required": ["cat"] },
          { "required": ["groups"] }
        ]
      },
      "properties": {
        "id": { "type": "string", "pattern": "^(th|st|ef|co|me|fg|db|ap)[0-9]+$" },
        "group": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "date": { "type": "string", "minLength": 1 },
        "loc": { "type": "string" },
        "coords": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "prefixItems": [
                { "type": "number", "minimum": -90, "maximum": 90 },
                { "type": "number", "minimum": -180, "maximum": 180 }
              ]
            }
          ]
        },
        "hint": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 },
        "repl": { "type": "string", "enum": ["robust", "mixed", "failed"] },
        "links": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(th|st|ef|co|me|fg|db|ap)[0-9]+$" }
        },
        "xlinks": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+::(th|st|ef|co|me|fg|db|ap)[0-9]+$" }
        },
        "keywords": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "lane": {
      "type": "object",
      "required": ["id", "events"],
      "properties": {
        "id": { "type": "string" },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "entryId": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
